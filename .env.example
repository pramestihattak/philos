# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Models
LLM_MODEL=qwen3.5:9b
EMBED_MODEL=nomic-embed-text

# Storage paths (relative to project root)
CHROMA_PERSIST_DIR=./data/vectorstore
DOCUMENTS_DIR=./data/documents

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Retrieval
TOP_K=5

# Generation
TEMPERATURE=0.1

# Auto-watch documents directory for new files (true/false)
WATCH_DOCUMENTS_DIR=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Disable ChromaDB anonymous telemetry (suppresses "capture() takes 1 positional argument" warnings)
ANONYMIZED_TELEMETRY=False

# API authentication — set a value to enable; empty = disabled (default, safe for localhost)
API_KEY=

# Max concurrent Ollama requests (embedder + LLM share this limit)
OLLAMA_CONCURRENCY=1
